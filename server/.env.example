# Copy to .env and adjust. All values are optional except where noted.

# TCP port to listen on.
PORT=8080

# Shown to clients in the Online tab.
SERVER_NAME=Flag Geo Server

# If set, clients must enter this password (sent to /auth) before they can do
# anything. Leave unset for an open server.
# SERVER_PASSWORD=changeme

# HMAC secret for session/room tokens. SET THIS in production — otherwise an
# ephemeral one is generated per process and all tokens break on restart.
# JWT_SECRET=please-change-me-to-a-long-random-string

# Comma-separated allowed browser origins (CORS). Use the exact origin the client
# is served from. "*" disables the allowlist (development only).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# SQLite database file for match history / leaderboard.
DB_PATH=flag-geo.db

# Capacity limits.
MAX_ROOMS=200
MAX_PLAYERS_PER_ROOM=16

# Pause between rounds (ms) and the hard cap for a round when a room sets no time
# limit (seconds).
ROUND_INTERMISSION_MS=2500
NO_LIMIT_ROUND_CAP_SEC=60

# Session/room token lifetime (seconds).
TOKEN_TTL_SEC=21600

# Log verbosity.
RUST_LOG=info
